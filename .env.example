# Hyperliquid agent (NOT main wallet) private key — generate at app.hyperliquid.xyz -> API
HYPERLIQUID_PRIVATE_KEY=0xyour_agent_private_key_here

# Your MAIN wallet address (the one that holds the USDC margin)
HYPERLIQUID_ADDRESS=0xyour_main_wallet_address_here

# Google Gemini API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# MiniMax API key — https://platform.minimax.io  (used in AI cycle + trade gate)
MINIMAX_API_KEY=your_minimax_api_key_here

# Anthropic API key — https://console.anthropic.com  (used in trade gate only)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
